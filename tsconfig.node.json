{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["bun"],
    "noEmit": true
  },
  "include": [
    "server",
    "scripts",
    "src/runeforge/data-access/runeforge-catalog.ts",
    "src/runeforge/util/runeforge-query.ts",
    "src/runeforge/util/runeforge-simulation.ts",
    "src/runeforge/util/runeforge-types.ts",
    "vite.config.ts",
    "eslint.config.js"
  ]
}
